# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI Compatible Config:
# OPENAI_API_KEY: Replace with your OpenAI API key or a compatible service key (e.g., Groq, Together AI).
OPENAI_API_KEY="your_openai_api_key"

# OPENAI_BASE_URL (Optional): Replace with your custom endpoint if using a compatible service other than OpenAI.
# OPENAI_BASE_URL="https://api.openai.com/v1"

# OPENAI_API_MODEL (Optional): The model to use. Defaults to "gpt-4o-mini".
# OPENAI_API_MODEL="gpt-4o-mini"

# Stripe Config
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

